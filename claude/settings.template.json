{
  "model": "claude-opus-4-8[1m]",
  "fallbackModel": ["claude-sonnet-5"],
  "permissions": { "defaultMode": "acceptEdits" },
  "statusLine": { "type": "command", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ~/.claude/statusline-command.ps1" },
  "effortLevel": "xhigh",
  "alwaysThinkingEnabled": true,
  "fastMode": true,
  "enableWorkflows": true,
  "workflowKeywordTriggerEnabled": true,
  "autoCompactEnabled": false,
  "theme": "dark",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "includeCoAuthoredBy": false,

  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:4000",
    "ANTHROPIC_AUTH_TOKEN": "__MASTER_KEY__",

    "ANTHROPIC_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "Opus 4.8 1M",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION": "Opus 4.8 1M via GitHub Copilot/LiteLLM",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "Sonnet 5 1M Backup",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION": "Fallback Sonnet model via GitHub Copilot/LiteLLM",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-opus-4-8[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "claude-opus-4-8[1m]",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "Opus 4.8 1M",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "Opus 4.8 1M via GitHub Copilot/LiteLLM",

    "CLAUDE_CODE_MAX_CONTEXT_TOKENS": "1000000",
    "CLAUDE_CODE_MAX_RETRIES": "2",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1"
  }
}
